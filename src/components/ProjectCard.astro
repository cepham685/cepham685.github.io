---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
---

<a href={`/work/${project.slug}`} class="card reveal" style={`transition-delay: ${index * 0.08}s`}>
  <div class="cover">
    <div class="cover-image" style={`background-image: url('${project.coverImage}')`}></div>
    <div class="overlay">
      <span class="view-label">View Project</span>
    </div>
  </div>
  <div class="info">
    <div class="meta">
      <span class="category">{project.category}</span>
      <span class="divider">/</span>
      <span class="year">{project.year}</span>
    </div>
    <h2>{project.title}</h2>
  </div>
</a>

<style>
  .card {
    display: block;
    cursor: pointer;
  }

  .cover {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .cover-image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 20, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.4s;
  }

  .view-label {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: white;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.3s, transform 0.3s, visibility 0.3s;
  }

  .card:hover .cover-image {
    transform: scale(1.05);
  }

  .card:hover .overlay {
    background: rgba(20, 20, 20, 0.4);
  }

  .card:hover .view-label {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .info {
    padding-top: 1rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .category,
  .year,
  .divider {
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .divider {
    opacity: 0.4;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
</style>
